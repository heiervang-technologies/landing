# Code: short cache so deploys propagate quickly. CF Pages globs are
# segment-based — name each top-level file explicitly.
/main.js
  Cache-Control: public, max-age=300, must-revalidate
/bomboc.js
  Cache-Control: public, max-age=300, must-revalidate
/clanker.js
  Cache-Control: public, max-age=300, must-revalidate
/sites.js
  Cache-Control: public, max-age=300, must-revalidate
/style.css
  Cache-Control: public, max-age=300, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Big binaries: cache long; we change the filename when content changes.
/assets/audio/*
  Cache-Control: public, max-age=2592000, immutable
/assets/fonts/*
  Cache-Control: public, max-age=2592000, immutable
/assets/hei/*
  Cache-Control: public, max-age=2592000, immutable
/assets/video/*
  Cache-Control: public, max-age=2592000, immutable
